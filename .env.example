# =========================================================================
# SECURITY WARNING: 
# DO NOT prefix sensitive keys with "VITE_". 
# Variables with "VITE_" prefix are exposed to the browser/client-side.
# =========================================================================

# Gemini API Key (Required for AI features)
# This is handled securely on the server.
GEMINI_API_KEY=

# Groq API Key (Optional fallback for Gemini quota limits)
GROQ_API_KEY=

# Optional: Add multiple keys for automatic rotation to bypass quota limits
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=
GEMINI_KEY_5=

